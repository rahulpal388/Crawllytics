{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./*.ts"
      ]
    },
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "path": {
    "@config/*": [
      "src/*"
    ]
  }
}